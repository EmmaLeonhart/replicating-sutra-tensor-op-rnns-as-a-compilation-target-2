// Demo: when an axon escapes the function (returned, here), the
// SSA-elision pass conservatively keeps all `add` calls — the
// receiver doesn't know which keys the caller will read.

vector v_cat = basis_vector("cat");
vector v_dog = basis_vector("dog");
vector v_mouse = basis_vector("mouse");

function vector make_axon() {
    Axon a;
    a.add("subject",     v_cat);
    a.add("object",      v_mouse);
    a.add("instrument",  v_dog);
    return a;
}

map<vector, string> ANIMAL_NAME = {
    v_cat:   "cat",
    v_dog:   "dog",
    v_mouse: "mouse"
};

function string main() {
    vector a = make_axon();
    // We're calling unbind(basis_vector("object"), a) by way of
    // axon_item-equivalent — but `a` here is just a vector, not a
    // typed Axon, so we have to use the substrate primitive.
    vector recovered = unbind(basis_vector("object"), a);
    vector winner = argmax_cosine(recovered, [v_cat, v_dog, v_mouse]);
    return ANIMAL_NAME[winner];
}
