// Flat knowledge graph — (subject, predicate, object) triples bundled
// into one memory vector, queried compositionally via bind/unbind.
//
// Encoding for rotation binding (role-first throughout):
//
//   triple(s, p, o) = bind(s, bind(p, o))
//                   = Q_s @ Q_p @ o
//
// Role-first means the first argument of bind is the key (seeds the
// rotation), the second is the filler (gets rotated). Nested bind
// composes rotations: outer key s, inner key p; retrieval applies
// the inverses in reverse order (Q_p^T then Q_s^T).
//
// Query (given s and p, recover o):
//
//   recovered = unbind(p, unbind(s, memory))
//             = Q_p^T @ Q_s^T @ memory
//
// Five animal/property triples, bundled into a single memory vector.
// Five queries recover each object by its (subject, predicate) key.

// --- Subjects (animals) ---
vector dog   = basis_vector("dog");
vector cat   = basis_vector("cat");
vector fish  = basis_vector("fish");
vector bird  = basis_vector("bird");
vector whale = basis_vector("whale");

// --- Predicates ---
vector has = basis_vector("has");
vector can = basis_vector("can");

// --- Objects ---
vector fur    = basis_vector("fur");
vector claws  = basis_vector("claws");
vector scales = basis_vector("scales");
vector fly    = basis_vector("fly");
vector swim   = basis_vector("swim");

map<vector, string> OBJECT_NAME = {
    fur:    "fur",
    claws:  "claws",
    scales: "scales",
    fly:    "fly",
    swim:   "swim"
};

// --- Bundled graph memory ---
// Each triple: bind(s, bind(p, o)) under rotation binding (role-first).
// Outer role = subject, inner role = predicate, innermost value = object.
vector graph = bundle(
    bind(dog,   bind(has, fur)),
    bind(cat,   bind(has, claws)),
    bind(fish,  bind(has, scales)),
    bind(bird,  bind(can, fly)),
    bind(whale, bind(can, swim))
);

// Query: given (subject, predicate), recover the object.
function string lookup_object(vector subject, vector predicate) {
    vector recovered = unbind(predicate, unbind(subject, graph));
    vector winner = argmax_cosine(recovered, [fur, claws, scales, fly, swim]);
    return OBJECT_NAME[winner];
}

function string main() {
    return lookup_object(dog, has);
}
