// Producer — half of the multi-program axon-passing demo.
//
// Builds a 5-key axon — chosen to stay within the empirical capacity
// of rotation binding on nomic-embedded fillers (per
// planning/findings/2026-04-22-rotation-binding-capacity-results.md).
// More keys produce crosstalk that defeats `argmax_cosine` recovery
// — that capacity wall is exactly what the spec's lazy-materialization
// optimization (axons.md §"Lazy evaluation across boundaries") is
// designed to push back. See README.md for the larger-N stress demo.
//
// The orchestrator (`_run.py`) calls make_state() to build the
// vector, serializes it, and hands it to the consumer running in a
// separate compiled module.

vector v_cat = basis_vector("cat");
vector v_dog = basis_vector("dog");
vector v_red = basis_vector("red");
vector v_blue = basis_vector("blue");
vector v_alice = basis_vector("alice");

function vector make_state() {
    Axon a;
    a.add("animal_1", v_cat);
    a.add("animal_2", v_dog);
    a.add("color_1",  v_red);
    a.add("color_2",  v_blue);
    a.add("user_1",   v_alice);
    return a;
}

function string main() {
    vector a = make_state();
    return "produced";
}
